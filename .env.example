# Copy this file to .env and fill in real values

# MongoDB (local dev uses localhost:27017)
MONGODB_URI=mongodb://localhost:27017/premier-sport-dev
MONGODB_DATABASE=premier-sport-dev

# JWT - generate a strong 32+ char secret
JWT_SECRET=change-me-to-a-strong-secret-32-chars-min
JWT_EXPIRATION=86400000

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (AWS SES SMTP or any SMTP provider)
MAIL_HOST=email-smtp.eu-west-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=your-ses-smtp-username
MAIL_PASSWORD=your-ses-smtp-password
MAIL_FROM=noreply@premier-sport.com

# OpenAI (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# AWS (for S3 image uploads)
AWS_S3_BUCKET=premier-sport-images
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
